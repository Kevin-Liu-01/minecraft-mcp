# Dedalus API key (required for chat-driven agent)
DEDALUS_API_KEY=

# Minecraft server for join_game (e.g. LAN world)
# Use 127.0.0.1 if the world is on this machine; use your LAN IP if the game is on another machine.
MINECRAFT_HOST=127.0.0.1
# Port from "Open to LAN" in-game (e.g. 61246)
MINECRAFT_PORT=61246

# Bot username in-game (optional)
# MINECRAFT_USERNAME=DedalusBot

# MCP URL for the Dedalus agent (default: local http://127.0.0.1:8000/mcp).
# For local-only use, leave unset. If the agent runs in the cloud and cannot reach localhost, set to a public URL (e.g. ngrok http 8000 → https://YOUR_NGROK_URL/mcp).
# AGENT_MCP_URL=https://YOUR_NGROK_URL/mcp

# Local MCP server URL (optional; used by run_tool.py, run_join_game.py)
# MCP_SERVER_URL=http://127.0.0.1:8000/mcp

# Model for the agent (optional)
# DEDALUS_MODEL=openai/gpt-5.2
